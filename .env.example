PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/exam_manager?schema=public
ARTIFACTS_OUTPUT_DIR=output/exam-batches
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# ---------------------------------------------------------------
# Módulo pedagógico (alunos, turmas, metas, avaliações, e-mail)
# ---------------------------------------------------------------
# Diretório onde os JSONs persistentes (students/goals/classes/...) são gravados.
JSON_STORAGE_DIR=data

# Configuração SMTP real para envio dos resumos diários.
# Deixe vazio para cair no ConsoleEmailService (desenvolvimento).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@education-analytics.local

# Intervalo de processamento do agendador em milissegundos. Se ausente, o
# agendador fica desligado e a fila pode ser drenada manualmente via
# POST /email/digest.
EMAIL_DIGEST_INTERVAL_MS=
